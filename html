let cart=[];
function renderPOS(){
  main.innerHTML=`<div class="topbar"><h1>${ic('pos')} فاتورة سريعة</h1></div>
  <div class="pos">
    <div class="panel">
      <div class="row"><input id="scan" placeholder="امسح الباركود (وحدة أو تجميعة) ثم Enter" autocomplete="off"><input id="quickName" class="search" placeholder="ابحث بالاسم لإضافة صنف..."></div>
      <div id="searchRes" class="flex" style="margin-bottom:8px"></div>
      <table><thead><tr><th>الصنف</th><th>النوع</th><th>السعر</th><th>الكمية</th><th>الإجمالي</th><th></th></tr></thead><tbody id="cartBody"></tbody></table>
    </div>
    <div class="panel">
      <div class="row"><select id="posCustomer"><option value="">زبون نقدي</option>${db.customers.map(c=>`<option value="${c.id}">${esc(c.name)}</option>`).join('')}</select><button class="btn sm" onclick="quickAddCustomer()">${ic('plus')} زبون</button></div>
      <div class="total-box" id="posTotal">0.00 ${cur()}</div>
      <div class="row"><div><label class="small">المدفوع</label><input id="posPaid" type="number" value="0" oninput="calcChange()"></div><div><label class="small">الباقي</label><input id="posChange" readonly value="0"></div></div>
      <div class="flex" style="margin-bottom:8px"><button class="btn sm" onclick="payExact()">دفع كامل المبلغ</button><button class="btn sm" onclick="setPaid(0)">آجل (0)</button></div>
      <div class="flex"><button class="btn ok" style="flex:1" onclick="saveSale(false)">${ic('save')} حفظ الفاتورة</button><button class="btn pri" style="flex:1" onclick="saveSale(true)">${ic('print')} حفظ وطباعة</button></div>
      <button class="btn" style="width:100%;margin-top:8px" onclick="cart=[];drawCart()">${ic('trash')} إفراغ الفاتورة</button>
    </div>
  </div>`;
  const scan=document.getElementById('scan');scan.focus();
  scan.addEventListener('keydown',e=>{if(e.key==='Enter'){addByBarcode(scan.value.trim());scan.value='';}});
  document.getElementById('quickName').addEventListener('input',e=>quickSearch(e.target.value));
  drawCart();
}
function quickSearch(q){const box=document.getElementById('searchRes');if(!q){box.innerHTML='';return;}const r=db.products.filter(p=>p.name.includes(q)||(p.barcode||'').includes(q)||(p.packBarcode||'').includes(q)).slice(0,8);box.innerHTML=r.map(p=>{let b=`<button class="btn sm" onclick="addToCart('${p.id}','unit');clrSearch()">${esc(p.name)} · ${esc(unitLabel(p))} ${money(p.price)}</button>`;if(hasPack(p))b+=`<button class="btn sm pri" onclick="addToCart('${p.id}','pack');clrSearch()">${esc(p.name)} · ${esc(packLabel(p))} (${pk(p)}) ${money(packPriceOf(p))}</button>`;return b;}).join('')||'<span class="small">لا نتائج</span>';}
function addByBarcode(code){if(!code)return;let p=db.products.find(x=>x.barcode===code);if(p){addToCart(p.id,'unit');return;}p=db.products.find(x=>x.packBarcode&&x.packBarcode===code);if(p){addToCart(p.id,'pack');return;}alert('لا يوجد صنف بهذا الباركود: '+code);}
function addToCart(id,mode){const p=pById(id);const isPack=(mode==='pack'&&hasPack(p));const factor=isPack?pk(p):1;const price=isPack?packPriceOf(p):p.price;const key=id+'|'+(isPack?'pack':'unit');const line=cart.find(l=>l.key===key);if(line){line.qty++;}else{cart.push({key,id,name:p.name,mode:(isPack?'pack':'unit'),price,qty:1,factor});}drawCart();}
function drawCart(){const body=document.getElementById('cartBody');if(!body)return;body.innerHTML=cart.map((l,i)=>{const p=pById(l.id);const typ=(l.factor&&l.factor>1)?(packLabel(p)+' ('+l.factor+')'):unitLabel(p);return `<tr><td>${esc(l.name)}</td><td><span class="pill ${l.factor>1?'y':'g'}">${esc(typ)}</span></td><td><input type="number" style="width:80px" value="${l.price}" onchange="cart[${i}].price=+this.value;drawCart()"></td><td><input type="number" style="width:70px" value="${l.qty}" min="1" onchange="cart[${i}].qty=+this.value;drawCart()"></td><td>${money(l.price*l.qty)}</td><td><button class="btn bad sm" onclick="cart.splice(${i},1);drawCart()">✕</button></td></tr>`;}).join('');const total=cart.reduce((a,l)=>a+l.price*l.qty,0);document.getElementById('posTotal').textContent=money(total);calcChange();}
function calcChange(){const total=cart.reduce((a,l)=>a+l.price*l.qty,0);const paid=+(document.getElementById('posPaid').value||0);document.getElementById('posChange').value=money(paid-total);}
function saveSale(print){if(!cart.length){alert('الفاتورة فارغة');return;}const total=cart.reduce((a,l)=>a+l.price*l.qty,0);const paid=+(document.getElementById('posPaid').value||0);const customerId=document.getElementById('posCustomer').value;const no=(db.sales.reduce((m,s)=>Math.max(m,s.no||0),0))+1;const sale={id:uid(),no,date:today(),time:new Date().toLocaleTimeString('ar'),customerId,items:cart.map(l=>({productId:l.id,qty:l.qty,price:l.price,mode:l.mode,factor:l.factor||1})),total,paid};
  cart.forEach(l=>{const p=pById(l.id);if(p&&p.id)p.qty-=l.qty*(l.factor||1);});db.sales.push(sale);save();if(print)printInvoice(sale);cart=[];drawCart();alert('تم حفظ الفاتورة رقم '+no);go('pos');}
function printInvoice(sale){const w=window.open('','_blank');const rows=sale.items.map(it=>{const _p=pById(it.productId);const _t=(it.factor&&it.factor>1)?(packLabel(_p)+'×'+it.factor):unitLabel(_p);return `<tr><td>${esc(_p.name||'')} <small>(${esc(_t)})</small></td><td>${it.qty}</td><td>${money(it.price)}</td><td>${money(it.qty*it.price)}</td></tr>`;}).join('');w.document.write(`<html dir=rtl><head><meta charset=utf-8><title>فاتورة ${sale.no}</title><style>body{font-family:Tahoma;padding:16px;max-width:360px}h2{text-align:center;margin:4px}table{width:100%;border-collapse:collapse;font-size:13px}td,th{border-bottom:1px dashed #999;padding:5px;text-align:right}.t{font-size:18px;font-weight:bold;text-align:left;margin-top:8px}</style></head><body><h2>${esc(db.settings.store)}</h2><div style=text-align:center>فاتورة رقم ${sale.no} — ${sale.date} ${sale.time||''}</div><div>الزبون: ${esc(cById(sale.customerId).name||'نقدي')}</div><hr><table><tr><th>الصنف</th><th>كمية</th><th>سعر</th><th>إجمالي</th></tr>${rows}</table><div class=t>الإجمالي: ${money(sale.total)}</div><div>المدفوع: ${money(sale.paid)}</div><div>الباقي: ${money(sale.paid-sale.total)}</div><hr><div style=text-align:center>شكراً لتسوقكم من Best Market</div><script>print()<\/script></body></html>`);w.document.close();}

