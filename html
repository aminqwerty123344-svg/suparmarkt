/* ============ الوارد (شراء من التجار) ============ */
let pItems=[];
function renderPurchases(){
  main.innerHTML=`<div class="topbar"><h1>${ic('in')} الوارد — فواتير الشراء</h1><button class="btn pri" onclick="newPurchase()">${ic('plus')} فاتورة شراء</button></div>
  <div class="panel">${tbl(['#','التاريخ','التاجر','عدد الأصناف','الإجمالي','المدفوع','المتبقي'],db.purchases.slice().reverse().map(p=>[p.no,p.date,esc(sById(p.supplierId).name||'-'),p.items.length,money(p.total),money(p.paid||0),`<span class="pill ${p.total-(p.paid||0)>0?'r':'g'}">${money(p.total-(p.paid||0))}</span>`]))||'<div class="small">لا فواتير شراء.</div>'}</div>`;
}
function newPurchase(){pItems=[];modal(purchaseForm());}
function purchaseForm(){return `<h3>${ic('in')} فاتورة شراء جديدة</h3>
  <div class="row"><div><label class="small">التاجر/المورّد *</label><select id="p_sup"><option value="">—</option>${db.suppliers.map(s=>`<option value="${s.id}">${esc(s.name)}</option>`).join('')}</select></div><div><label class="small">التاريخ</label><input id="p_date" type="date" value="${today()}"></div></div>
  <div class="panel" style="padding:10px;box-shadow:none;background:var(--soft)"><div class="row"><select id="p_prod" onchange="pFillCost()"><option value="">اختر صنف...</option>${db.products.map(p=>`<option value="${p.id}">${esc(p.name)}</option>`).join('')}</select><select id="p_mode" onchange="pFillCost()"><option value="unit">وحدة (مفرق)</option><option value="pack">تجميعة (كرتون)</option></select></div><div class="row"><input id="p_qty" type="number" placeholder="الكمية" value="1"><input id="p_cost" type="number" placeholder="سعر الكلفة"><button class="btn pri" onclick="addPItem()">${ic('plus')} إضافة</button></div><div class="small" id="p_hint" style="margin-bottom:6px"></div><table><thead><tr><th>الصنف</th><th>النوع</th><th>كمية</th><th>كلفة</th><th>إجمالي</th><th></th></tr></thead><tbody id="pBody"></tbody></table></div>
  <div class="row"><div><label class="small">المدفوع الآن</label><input id="p_paid" type="number" value="0"></div><div class="total-box" id="pTotal" style="font-size:20px">0.00</div></div>
  <div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="savePurchase()">حفظ الفاتورة</button></div>`;}
function addPItem(){const id=val('p_prod');if(!id){alert('اختر صنفاً');return;}const p=pById(id);const mode=val('p_mode');const factor=(mode==='pack'&&hasPack(p))?pk(p):1;const qty=+val('p_qty')||1;const cost=+val('p_cost')||(factor>1?packCostOf(p):p.cost);pItems.push({productId:id,qty,cost,factor});drawP();}
function drawP(){document.getElementById('pBody').innerHTML=pItems.map((it,i)=>{const p=pById(it.productId);const typ=(it.factor&&it.factor>1)?(packLabel(p)+' ('+it.factor+')'):unitLabel(p);return `<tr><td>${esc(p.name)}</td><td><span class="pill ${it.factor>1?'y':'g'}">${esc(typ)}</span></td><td>${it.qty}</td><td>${money(it.cost)}</td><td>${money(it.qty*it.cost)}</td><td><button class="btn bad sm" onclick="pItems.splice(${i},1);drawP()">✕</button></td></tr>`;}).join('');document.getElementById('pTotal').textContent=money(pItems.reduce((a,i)=>a+i.qty*i.cost,0));}
function savePurchase(){const supplierId=val('p_sup');if(!supplierId){alert('اختر التاجر');return;}if(!pItems.length){alert('أضف أصنافاً');return;}const total=pItems.reduce((a,i)=>a+i.qty*i.cost,0);const no=(db.purchases.reduce((m,p)=>Math.max(m,p.no||0),0))+1;db.purchases.push({id:uid(),no,date:val('p_date'),supplierId,items:pItems.slice(),total,paid:+val('p_paid')});pItems.forEach(it=>{const p=pById(it.productId);if(p&&p.id){const f=it.factor||1;p.qty+=it.qty*f;p.cost=+(it.cost/f).toFixed(4);}});save();closeModal();renderPurchases();}

