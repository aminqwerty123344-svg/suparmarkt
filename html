  <div class="row"><div><label class="small">اسم الوحدة (مفرق)</label><input id="f_unit" value="${esc(p.unitName||'')}" placeholder="علبة / قطعة"></div></div>
  <div class="panel" style="padding:12px;background:var(--soft);box-shadow:none;margin:6px 0"><div class="small" style="margin-bottom:8px;font-weight:700">التجميعة / الكرتون (اختياري)</div><div class="row"><div><label class="small">اسم التجميعة</label><input id="f_packname" value="${esc(p.packName||'')}" placeholder="كرتون / كروز"></div><div><label class="small">عدد الوحدات بالتجميعة</label><input id="f_packsize" type="number" value="${p.packSize||1}" placeholder="24"></div></div><div class="row"><div><label class="small">باركود التجميعة</label><input id="f_packbarcode" value="${esc(p.packBarcode||'')}"></div><div><label class="small">سعر بيع التجميعة</label><input id="f_packprice" type="number" value="${p.packPrice||0}"></div></div><div class="small">اترك سعر التجميعة = 0 ليُحسب تلقائياً (سعر الوحدة × العدد).</div></div>
  <div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="saveProduct('${id||''}')">حفظ</button></div>`);}
function saveProduct(id){const name=val('f_name');if(!name){alert('اكتب اسم الصنف');return;}const o={barcode:val('f_barcode'),name,category:val('f_cat'),supplierId:val('f_sup'),cost:+val('f_cost'),price:+val('f_price'),qty:+val('f_qty'),min:+val('f_min'),unitName:val('f_unit'),packName:val('f_packname'),packSize:+val('f_packsize')||1,packPrice:+val('f_packprice')||0,packBarcode:val('f_packbarcode')};if(id){Object.assign(pById(id),o);}else{o.id=uid();db.products.push(o);}save();closeModal();renderProducts();}
