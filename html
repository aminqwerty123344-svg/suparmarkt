}
function editCustomer(id){const c=id?cById(id):{name:'',phone:'',note:''};modal(`<h3>${id?'تعديل زبون':'زبون جديد'}</h3><div class="row"><div><label class="small">الاسم *</label><input id="c_name" value="${esc(c.name)}"></div><div><label class="small">الهاتف</label><input id="c_phone" value="${esc(c.phone||'')}"></div></div><div class="row"><div><label class="small">ملاحظات</label><input id="c_note" value="${esc(c.note||'')}"></div></div><div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="saveCustomer('${id||''}')">حفظ</button></div>`);}
function saveCustomer(id){const name=val('c_name');if(!name){alert('اكتب الاسم');return;}const o={name,phone:val('c_phone'),note:val('c_note')};if(id)Object.assign(cById(id),o);else{o.id=uid();db.customers.push(o);}save();closeModal();renderCustomers();}
function delCustomer(id){if(confirm('حذف الزبون؟')){db.customers=db.customers.filter(c=>c.id!==id);save();renderCustomers();}}

/* ============ سندات القبض/الدفع + كشوف الحساب (PDF) ============ */
function custPayModal(id){const c=cById(id);modal(`<h3>${ic('down')} سند قبض من ${esc(c.name)}</h3><div class="small" style="margin-bottom:8px">الرصيد الحالي على الزبون: <b>${money(customerBalance(id))}</b></div><div class="row"><div><label class="small">المبلغ المقبوض *</label><input id="cp_amount" type="number"></div><div><label class="small">التاريخ</label><input id="cp_date" type="date" value="${today()}"></div></div><div class="row"><div><label class="small">ملاحظات</label><input id="cp_note" placeholder="دفعة على الحساب"></div></div><div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="saveCustPay('${id}')">حفظ</button></div>`);}
function saveCustPay(id){const amount=+val('cp_amount');if(!amount||amount<=0){alert('أدخل مبلغاً صحيحاً');return;}db.custPays=db.custPays||[];db.custPays.push({id:uid(),customerId:id,amount,date:val('cp_date')||today(),note:val('cp_note')});save();closeModal();renderCustomers();}
function supPayModal(id){const s=sById(id);modal(`<h3>${ic('up')} سند دفع إلى ${esc(s.name)}</h3><div class="small" style="margin-bottom:8px">الرصيد الحالي للتاجر علينا: <b>${money(supplierBalance(id))}</b></div><div class="row"><div><label class="small">المبلغ المدفوع *</label><input id="sp_amount" type="number"></div><div><label class="small">التاريخ</label><input id="sp_date" type="date" value="${today()}"></div></div><div class="row"><div><label class="small">ملاحظات</label><input id="sp_note" placeholder="دفعة على الحساب"></div></div><div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="saveSupPay('${id}')">حفظ</button></div>`);}
function saveSupPay(id){const amount=+val('sp_amount');if(!amount||amount<=0){alert('أدخل مبلغاً صحيحاً');return;}db.supPays=db.supPays||[];db.supPays.push({id:uid(),supplierId:id,amount,date:val('sp_date')||today(),note:val('sp_note')});save();closeModal();renderSuppliers();}
function custLedger(id){const rows=[];db.sales.filter(s=>s.customerId===id).forEach(s=>rows.push({date:s.date,desc:'فاتورة بيع #'+s.no,due:s.total,paid:(s.paid||0)}));(db.custPays||[]).filter(p=>p.customerId===id).forEach(p=>rows.push({date:p.date,desc:'سند قبض'+(p.note?' — '+p.note:''),due:0,paid:p.amount}));return rows.sort((a,b)=>(a.date>b.date?1:-1));}
function supLedger(id){const rows=[];db.purchases.filter(p=>p.supplierId===id).forEach(p=>rows.push({date:p.date,desc:'فاتورة شراء #'+p.no,due:p.total,paid:(p.paid||0)}));(db.supPays||[]).filter(x=>x.supplierId===id).forEach(x=>rows.push({date:x.date,desc:'سند دفع'+(x.note?' — '+x.note:''),due:0,paid:x.amount}));return rows.sort((a,b)=>(a.date>b.date?1:-1));}
function custStatement(id){printStatement('زبون',cById(id),custLedger(id),'مستحق على الزبون (لصالح المحل)','رصيد للزبون لدى المحل');}
function supStatement(id){printStatement('تاجر',sById(id),supLedger(id),'مستحق للتاجر (على المحل)','رصيد للمحل لدى التاجر');}
function printStatement(kind,party,ledger,posLabel,negLabel){let run=0;const body=ledger.map(r=>{run+=(r.due||0)-(r.paid||0);return `<tr><td>${r.date||''}</td><td>${esc(r.desc)}</td><td>${r.due?money(r.due):''}</td><td>${r.paid?money(r.paid):''}</td><td><b>${money(run)}</b></td></tr>`;}).join('');const final=run;const w=window.open('','_blank');w.document.write(`<html dir=rtl><head><meta charset=utf-8><title>كشف حساب ${esc(party.name||'')}</title><style>body{font-family:Tahoma;padding:20px;color:#123026}h2{margin:0}.hd{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:2px solid #1f9d6b;padding-bottom:10px;margin-bottom:14px}.muted{color:#666;font-size:13px}table{width:100%;border-collapse:collapse;font-size:13px}th,td{border-bottom:1px solid #e6e6e6;padding:7px;text-align:right}th{background:#eef4f1}.fin{margin-top:16px;font-size:16px;font-weight:bold;text-align:left;background:#e6f3ec;padding:10px;border-radius:8px}.sign{text-align:center;color:#888;font-size:12px;margin-top:26px}</style></head><body><div class="hd"><div><h2>${esc(db.settings.store)}</h2><div class="muted">كشف حساب ${kind}</div></div><div style="text-align:left"><div><b>${esc(party.name||'')}</b></div><div class="muted">${esc(party.phone||'')}</div><div class="muted">بتاريخ ${today()}</div></div></div><table><thead><tr><th>التاريخ</th><th>البيان</th><th>استحقاق</th><th>مسدّد</th><th>الرصيد</th></tr></thead><tbody>${body||'<tr><td colspan=5 style=text-align:center>لا توجد حركات.</td></tr>'}</tbody></table><div class="fin">الرصيد النهائي: ${money(Math.abs(final))} — ${final>=0?posLabel:negLabel}</div><div class="sign">صدر هذا الكشف آلياً — للحصول على PDF اختر «حفظ بصيغة PDF» في نافذة الطباعة</div><script>print()<\/script></body></html>`);w.document.close();}

/* ============ العاملون: الأجور والسلف ============ */
function eById(id){return db.employees.find(e=>e.id===id)||{};}
function payTypeLabel(e){return ({daily:'يومي',weekly:'أسبوعي',monthly:'شهري'})[(e&&e.payType)||'monthly']||'شهري';}
function empAccrued(id){return db.payroll.filter(x=>x.empId===id&&x.type==='wage').reduce((a,x)=>a+(+x.amount||0),0);}
function empAdvances(id){return db.payroll.filter(x=>x.empId===id&&x.type==='advance').reduce((a,x)=>a+(+x.amount||0),0);}
function empPaid(id){return db.payroll.filter(x=>x.empId===id&&x.type==='payment').reduce((a,x)=>a+(+x.amount||0),0);}
function empBalance(id){return empAccrued(id)-empAdvances(id)-empPaid(id);}
function renderEmployees(){
  main.innerHTML=`<div class="topbar"><h1>${ic('emp')} العاملون — الأجور والسلف</h1><button class="btn pri" onclick="editEmployee()">${ic('plus')} عامل جديد</button></div><br>  <div class="cards"><div class="stat"><div class="n">${db.employees.length}</div><div class="l">عدد العاملين</div></div><div class="stat"><div class="n" style="color:var(--warn)">${money(db.employees.reduce((a,e)=>a+empAdvances(e.id),0))}</div><div class="l">إجمالي السلف</div></div><div class="stat"><div class="n" style="color:var(--pri2)">${money(db.employees.reduce((a,e)=>a+(empBalance(e.id)>0?empBalance(e.id):0),0))}</div><div class="l">مستحقات للعاملين</div></div></div><br>  <div class="panel">${tbl(['العامل','الهاتف','الأجر / النوع','مستحق (أجور)','السلف','المدفوع','الرصيد له','إجراءات'],db.employees.map(e=>[esc(e.name),esc(e.phone||'-'),`${money(e.salary||0)} <span class="small">/ ${payTypeLabel(e)}</span>`,money(empAccrued(e.id)),`<span class="pill y">${money(empAdvances(e.id))}</span>`,money(empPaid(e.id)),`<span class="pill ${empBalance(e.id)>=0?'g':'r'}">${money(empBalance(e.id))}</span>`,`<button class="btn sm ok" onclick="payrollModal('${e.id}','wage')">أجر</button> <button class="btn sm warn" onclick="payrollModal('${e.id}','advance')">سلفة</button> <button class="btn sm pri" onclick="payrollModal('${e.id}','payment')">صرف</button> <button class="btn sm" onclick="empStatement('${e.id}')">كشف</button> <button class="btn sm" onclick="editEmployee('${e.id}')">${ic('edit')}</button> <button class="btn bad sm" onclick="delEmployee('${e.id}')">${ic('trash')}</button>`]))||'<div class="small">لا عاملين بعد. أضف عاملاً جديداً.</div>'}</div>`;
}
function editEmployee(id){const e=id?eById(id):{name:'',phone:'',salary:0,note:'',payType:'monthly'};const pt=e.payType||'monthly';modal(`<h3>${id?'تعديل عامل':'عامل جديد'}</h3><div class="row"><div><label class="small">الاسم *</label><input id="e_name" value="${esc(e.name)}"></div><div><label class="small">الهاتف</label><input id="e_phone" value="${esc(e.phone||'')}"></div></div><div class="row"><div><label class="small">نوع الأجر</label><select id="e_paytype"><option value="daily" ${pt==='daily'?'selected':''}>يومي</option><option value="weekly" ${pt==='weekly'?'selected':''}>أسبوعي</option><option value="monthly" ${pt==='monthly'?'selected':''}>شهري</option></select></div><div><label class="small">قيمة الأجر (لكل فترة)</label><input id="e_salary" type="number" value="${e.salary||0}"></div></div><div class="row"><div><label class="small">ملاحظات</label><input id="e_note" value="${esc(e.note||'')}"></div></div><div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="saveEmployee('${id||''}')">حفظ</button></div>`);}
function saveEmployee(id){const name=val('e_name');if(!name){alert('اكتب اسم العامل');return;}const o={name,phone:val('e_phone'),salary:+val('e_salary')||0,note:val('e_note'),payType:val('e_paytype')||'monthly'};if(id)Object.assign(eById(id),o);else{o.id=uid();db.employees.push(o);}save();closeModal();renderEmployees();}
function delEmployee(id){if(confirm('حذف العامل وجميع حركاته؟')){db.employees=db.employees.filter(e=>e.id!==id);db.payroll=db.payroll.filter(x=>x.empId!==id);save();renderEmployees();}}
function payrollModal(empId,type){const e=eById(empId);const titles={wage:'إضافة أجر مستحق',advance:'تسجيل سلفة',payment:'صرف / دفع أجر'};const def=(type==='wage')?(e.salary||0):0;modal(`<h3>${titles[type]||''} — ${esc(e.name)}</h3><div class="small" style="margin-bottom:8px">الرصيد الحالي المستحق له: <b>${money(empBalance(empId))}</b> · نوع الأجر: ${payTypeLabel(e)}</div><div class="row"><div><label class="small">المبلغ *</label><input id="pr_amount" type="number" value="${def}"></div><div><label class="small">التاريخ</label><input id="pr_date" type="date" value="${today()}"></div></div><div class="row"><div><label class="small">ملاحظات</label><input id="pr_note" placeholder="مثال: راتب شهر 6 / سلفة"></div></div><div class="flex" style="justify-content:flex-end"><button class="btn" onclick="closeModal()">إلغاء</button><button class="btn ok" onclick="savePayroll('${empId}','${type}')">حفظ</button></div>`);}
function savePayroll(empId,type){const amount=+val('pr_amount');if(!amount||amount<=0){alert('أدخل مبلغاً صحيحاً');return;}db.payroll.push({id:uid(),empId,type,amount,date:val('pr_date')||today(),note:val('pr_note')});save();closeModal();renderEmployees();}
function empStatement(empId){const e=eById(empId);const label={wage:'أجر مستحق',advance:'سلفة',payment:'صرف'};const rows=db.payroll.filter(x=>x.empId===empId).slice().sort((a,b)=>(a.date>b.date?1:-1)).map(x=>`<tr><td>${x.date}</td><td><span class="pill ${x.type==='wage'?'g':(x.type==='advance'?'y':'r')}">${label[x.type]||x.type}</span></td><td>${money(x.amount)}</td><td>${esc(x.note||'')}</td><td><button class="btn bad sm" onclick="db.payroll=db.payroll.filter(z=>z.id!=='${x.id}');save();empStatement('${empId}')">✕</button></td></tr>`).join('');modal(`<h3>${ic('emp')} كشف حساب — ${esc(e.name)}</h3><div class="cards" style="margin-bottom:10px"><div class="stat"><div class="n">${money(empAccrued(empId))}</div><div class="l">إجمالي الأجور</div></div><div class="stat"><div class="n" style="color:var(--warn)">${money(empAdvances(empId))}</div><div class="l">إجمالي السلف</div></div><div class="stat"><div class="n" style="color:var(--pri2)">${money(empBalance(empId))}</div><div class="l">الرصيد المتبقي له</div></div></div><table><thead><tr><th>التاريخ</th><th>النوع</th><th>المبلغ</th><th>ملاحظة</th><th></th></tr></thead><tbody>${rows||'<tr><td colspan="5" class="small">لا حركات.</td></tr>'}</tbody></table><div class="flex" style="justify-content:flex-end;margin-top:10px"><button class="btn" onclick="closeModal()">إغلاق</button></div>`);}

/* ============ التقارير ============ */
function renderReports(){
  const from=today().slice(0,8)+'01';
  main.innerHTML=`<div class="topbar"><h1>${ic('chart')} التقارير</h1><div class="flex"><input type="date" id="rFrom" value="${from}"><input type="date" id="rTo" value="${today()}"><button class="btn pri" onclick="runReport()">عرض</button></div></div><div id="reportOut"></div>`;runReport();
}
function runReport(){const from=val('rFrom'),to=val('rTo');const sales=db.sales.filter(s=>s.date>=from&&s.date<=to);const purch=db.purchases.filter(p=>p.date>=from&&p.date<=to);const sTot=sales.reduce((a,s)=>a+s.total,0);const pTot=purch.reduce((a,p)=>a+p.total,0);
  let cogs=0;sales.forEach(s=>s.items.forEach(it=>cogs+=it.qty*(it.factor||1)*(pById(it.productId).cost||0)));
  const out=document.getElementById('reportOut');out.innerHTML=`<div class="cards"><div class="stat"><div class="n" style="color:var(--ok)">${money(sTot)}</div><div class="l">المبيعات</div></div><div class="stat"><div class="n">${money(pTot)}</div><div class="l">المشتريات</div></div><div class="stat"><div class="n">${money(cogs)}</div><div class="l">تكلفة البضاعة المباعة</div></div><div class="stat"><div class="n" style="color:var(--pri2)">${money(sTot-cogs)}</div><div class="l">الربح التقديري</div></div></div>
  <div class="panel"><h3>أكثر الأصناف مبيعاً</h3>${topProducts(sales)}</div>`;
}
function topProducts(sales){const m={};sales.forEach(s=>s.items.forEach(it=>{m[it.productId]=(m[it.productId]||0)+it.qty*(it.factor||1);}));const rows=Object.entries(m).sort((a,b)=>b[1]-a[1]).slice(0,10).map(([id,q])=>[esc(pById(id).name||'-'),q]);return rows.length?tbl(['الصنف','الكمية المباعة'],rows):'<div class="small">لا بيانات.</div>';}

/* ============ الإعدادات + النسخ الاحتياطي ============ */
function renderSettings(){
  main.innerHTML=`<div class="topbar"><h1>${ic('gear')} الإعدادات</h1></div>
  <div class="panel"><h3>بيانات المتجر</h3><div class="row"><div><label class="small">اسم المتجر</label><input id="set_store" value="${esc(db.settings.store)}"></div><div><label class="small">العملة</label><input id="set_cur" value="${esc(db.settings.currency)}"></div></div><button class="btn ok" onclick="saveSettings()">حفظ</button></div>
  <div class="panel"><h3>النسخ الاحتياطي</h3><div class="flex"><button class="btn pri" onclick="backup()">${ic('down')} تصدير نسخة احتياطية</button><label class="btn warn">${ic('up')} استيراد نسخة<input type="file" accept=".json" style="display:none" onchange="restore(event)"></label><button class="btn bad" onclick="wipe()">${ic('trash')} مسح كل البيانات</button></div></div>`;
}
function saveSettings(){db.settings.store=val('set_store');db.settings.currency=val('set_cur');save();alert('تم الحفظ');renderDash();current='settings';go('settings');}
function backup(){const blob=new Blob([JSON.stringify(db,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='best-market-backup-'+today()+'.json';a.click();}
function restore(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=()=>{try{db=Object.assign(defaultDB(),JSON.parse(r.result));save();alert('تم الاستيراد');go('dash');}catch(err){alert('ملف غير صالح');}};r.readAsText(f);}
function wipe(){if(confirm('سيتم مسح جميع البيانات نهائياً. متابعة؟')){localStorage.removeItem(KEY);db=defaultDB();go('dash');}}

/* ============ أدوات مساعدة ============ */
function val(id){const e=document.getElementById(id);return e?e.value.trim():'';}
function modal(html){closeModal();const d=document.createElement('div');d.className='modal';d.id='modal';d.innerHTML='<div class="box">'+html+'</div>';d.addEventListener('click',e=>{if(e.target===d)closeModal();});document.body.appendChild(d);}
function closeModal(){const m=document.getElementById('modal');if(m)m.remove();}

render();
</script>
</body>
</html>
