<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Best Market — نظام محاسبي</title>
<style>
:root{
--bg:#0c3b2c;--bg2:#093023;--card:#ffffff;--muted:#6f887d;--line:#e6efe9;--soft:#eef4f1;--page:#f4f8f6;
--pri:#1f9d6b;--pri2:#16764f;--pri-soft:#e6f3ec;
--ok:#1f9d6b;--warn:#a9822f;--bad:#a2493c;
--gold:#a9822f;--gold-soft:#f5edda;--danger:#a2493c;--danger-soft:#f4e5e2;
--shadow:0 1px 2px rgba(16,42,30,.05),0 6px 18px rgba(16,42,30,.06);
}
*{box-sizing:border-box;font-family:'Segoe UI',Tahoma,Arial,sans-serif}
body{margin:0;background:var(--page);color:var(--ink,#123026)}
.app{display:flex;min-height:100vh}
.side{width:238px;background:linear-gradient(180deg,var(--bg),var(--bg2));color:#c3d8cd;padding:18px 14px;position:sticky;top:0;height:100vh;overflow:auto}
.brand{display:flex;align-items:center;gap:10px;font-weight:700;font-size:18px;color:#fff;margin-bottom:22px;padding:0 4px}
.brand .logo{display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:11px;background:var(--pri);color:#fff;flex:none}
.brand .logo svg{width:19px;height:19px}
.nav a{display:flex;align-items:center;gap:11px;padding:11px 12px;border-radius:11px;color:#bcd3c7;text-decoration:none;cursor:pointer;margin-bottom:3px;font-size:14.5px;transition:.15s}
.nav a:hover{background:rgba(255,255,255,.08);color:#fff}
.nav a.active{background:var(--pri);color:#fff;font-weight:600;box-shadow:0 6px 16px rgba(31,157,107,.35)}
.nav a .ic{width:19px;height:19px}
.main{flex:1;padding:24px 26px;overflow:auto}
.topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px}
.topbar h1{font-size:21px;margin:0;font-weight:700;display:flex;align-items:center;gap:9px}
.topbar h1 .ic{color:var(--pri);width:22px;height:22px}
.btn{border:0;border-radius:10px;padding:9px 15px;cursor:pointer;font-size:14px;font-weight:600;background:var(--soft);color:#123026;display:inline-flex;align-items:center;justify-content:center;gap:7px;transition:.15s}
.btn:hover{filter:brightness(.97)}
.btn .ic{width:16px;height:16px}
.btn.pri{background:var(--pri);color:#fff}.btn.ok{background:var(--pri2);color:#fff}.btn.bad{background:var(--bad);color:#fff}.btn.warn{background:var(--warn);color:#fff}
.btn.sm{padding:6px 9px;font-size:12px;border-radius:8px}
.btn.sm .ic{width:14px;height:14px}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;margin-bottom:20px}
.stat{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:17px 18px;box-shadow:var(--shadow)}
.stat .n{font-size:23px;font-weight:800;letter-spacing:-.3px}
.stat .l{color:var(--muted);font-size:12.5px;margin-top:5px}
.panel{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:18px;margin-bottom:16px;box-shadow:var(--shadow)}
.panel h3{margin:0 0 14px;font-size:15.5px;display:flex;align-items:center;gap:8px}
.panel h3 .ic{color:var(--pri);width:18px;height:18px}
table{width:100%;border-collapse:collapse;font-size:14px}
th,td{padding:10px 11px;text-align:right;border-bottom:1px solid var(--line)}
th{background:var(--soft);color:#3c5a4e;font-weight:700;position:sticky;top:0}
tr:hover td{background:#f7faf8}
input,select{padding:9px 11px;border:1px solid var(--line);border-radius:10px;font-size:14px;width:100%;background:#fff;color:#123026}
input:focus,select:focus{outline:2px solid var(--pri-soft);border-color:var(--pri)}
.row{display:grid;gap:10px;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));margin-bottom:10px}
.pill{padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700;display:inline-block}
.pill.g{background:var(--pri-soft);color:#14654a}.pill.r{background:var(--danger-soft);color:#8a3b30}.pill.y{background:var(--gold-soft);color:#7c5e22}
.hide{display:none}
.pos{display:grid;grid-template-columns:1.4fr 1fr;gap:16px}
@media(max-width:900px){.pos{grid-template-columns:1fr}.side{width:66px}.brand .name,.nav a .lbl{display:none}.brand{justify-content:center}.nav a{justify-content:center}}
.total-box{font-size:29px;font-weight:800;color:var(--pri2);text-align:center;padding:12px;background:var(--pri-soft);border-radius:14px;margin:10px 0}
.modal{position:fixed;inset:0;background:rgba(9,30,22,.5);display:flex;align-items:center;justify-content:center;z-index:50}
.modal .box{background:#fff;border-radius:18px;padding:22px;width:min(520px,92vw);max-height:90vh;overflow:auto;box-shadow:0 20px 60px rgba(9,30,22,.28)}
.small{color:var(--muted);font-size:12px}
.right{text-align:left}
.flex{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.search{max-width:280px}
.ic{display:inline-flex;align-items:center;justify-content:center;width:1.1em;height:1.1em;vertical-align:-.18em;flex:none}
.ic svg{width:100%;height:100%;display:block}
</style>
</head>
<body>
<div class="app">
  <aside class="side">
    <div class="brand"><span class="logo"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9.5" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M2.5 4h2.2l2.3 12h10.4L20 8H6.2"/></svg></span><span class="name">Best Market</span></div>
    <nav class="nav" id="nav">
      <a data-view="dash" class="active"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7.5" height="7.5" rx="1.6"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.6"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.6"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.6"/></svg></span><span class="lbl">لوحة التحكم</span></a>
      <a data-view="pos"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2.5h12v19l-2-1.3-2 1.3-2-1.3-2 1.3-2-1.3-2 1.3z"/><path d="M9 7.5h6M9 11h6M9 14.5h4"/></svg></span><span class="lbl">فاتورة سريعة</span></a>
      <a data-view="products"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.4l-9-5-9 5v7.2l9 5 9-5z"/><path d="M3.3 8.2L12 13l8.7-4.8M12 13v9.4"/></svg></span><span class="lbl">البضاعة</span></a>
      <a data-view="purchases"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v10m0 0l-3.5-3.5M12 13l3.5-3.5"/><path d="M4 15.5V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3.5"/></svg></span><span class="lbl">الوارد (شراء)</span></a>
      <a data-view="sales"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 13.5v-10m0 0L8.5 7M12 3.5l3.5 3.5"/><path d="M4 15.5V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3.5"/></svg></span><span class="lbl">الصادر (بيع)</span></a>
      <a data-view="inventory"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="12" height="17" rx="2.2"/><path d="M9.2 4V3.2A1.2 1.2 0 0 1 10.4 2h3.2a1.2 1.2 0 0 1 1.2 1.2V4"/><path d="M9 12.6l2 2 4-4"/></svg></span><span class="lbl">الجرد</span></a>
      <a data-view="suppliers"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.5h11v9H3z"/><path d="M14 9.5h3.6l3.4 3.4v2.6H14z"/><circle cx="7" cy="18" r="1.7"/><circle cx="17.3" cy="18" r="1.7"/></svg></span><span class="lbl">التجار</span></a>
      <a data-view="customers"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20v-1a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v1"/><circle cx="9.5" cy="8" r="3.2"/><path d="M17.6 4.7a3.2 3.2 0 0 1 0 6.1M22 20v-1a4 4 0 0 0-3-3.86"/></svg></span><span class="lbl">الزبائن</span></a>
      <a data-view="employees"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="17" rx="2"/><circle cx="12" cy="10" r="2.5"/><path d="M8 17c0-2 1.8-3 4-3s4 1 4 3"/></svg></span><span class="lbl">العاملون</span></a>
      <a data-view="reports"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v16h16"/><path d="M8 15l3-4 3 2 4-6"/></svg></span><span class="lbl">التقارير</span></a>
      <a data-view="settings"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h9M17 7h3"/><path d="M4 12h3M11 12h9"/><path d="M4 17h11M19 17h1"/><circle cx="15" cy="7" r="2"/><circle cx="9" cy="12" r="2"/><circle cx="17" cy="17" r="2"/></svg></span><span class="lbl">الإعدادات</span></a>
    </nav>
  </aside>
  <main class="main" id="main"></main>
</div>

<script>
/* ============ التخزين والبيانات ============ */
const KEY='bestMarketDB';
function defaultDB(){return{settings:{store:'Best Market',currency:'ر.س',tax:0},products:[],suppliers:[],customers:[],purchases:[],sales:[],employees:[],payroll:[],custPays:[],supPays:[]}}
let db=load();
function load(){try{return Object.assign(defaultDB(),JSON.parse(localStorage.getItem(KEY)))}catch(e){return defaultDB()}}
function save(){localStorage.setItem(KEY,JSON.stringify(db));}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6)}
const cur=()=>db.settings.currency||'';
function money(n){return (Number(n)||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})+' '+cur()}
function today(){return new Date().toISOString().slice(0,10)}
const IC=(p)=>`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
const ICONS={dash:IC('<rect x="3" y="3" width="7.5" height="7.5" rx="1.6"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.6"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.6"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.6"/>'),pos:IC('<path d="M6 2.5h12v19l-2-1.3-2 1.3-2-1.3-2 1.3-2-1.3-2 1.3z"/><path d="M9 7.5h6M9 11h6M9 14.5h4"/>'),box:IC('<path d="M21 8.4l-9-5-9 5v7.2l9 5 9-5z"/><path d="M3.3 8.2L12 13l8.7-4.8M12 13v9.4"/>'),in:IC('<path d="M12 3v10m0 0l-3.5-3.5M12 13l3.5-3.5"/><path d="M4 15.5V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3.5"/>'),out:IC('<path d="M12 13.5v-10m0 0L8.5 7M12 3.5l3.5 3.5"/><path d="M4 15.5V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3.5"/>'),inv:IC('<rect x="6" y="4" width="12" height="17" rx="2.2"/><path d="M9.2 4V3.2A1.2 1.2 0 0 1 10.4 2h3.2a1.2 1.2 0 0 1 1.2 1.2V4"/><path d="M9 12.6l2 2 4-4"/>'),truck:IC('<path d="M3 6.5h11v9H3z"/><path d="M14 9.5h3.6l3.4 3.4v2.6H14z"/><circle cx="7" cy="18" r="1.7"/><circle cx="17.3" cy="18" r="1.7"/>'),users:IC('<path d="M16 20v-1a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v1"/><circle cx="9.5" cy="8" r="3.2"/><path d="M17.6 4.7a3.2 3.2 0 0 1 0 6.1M22 20v-1a4 4 0 0 0-3-3.86"/>'),chart:IC('<path d="M4 4v16h16"/><path d="M8 15l3-4 3 2 4-6"/>'),gear:IC('<path d="M4 7h9M17 7h3"/><path d="M4 12h3M11 12h9"/><path d="M4 17h11M19 17h1"/><circle cx="15" cy="7" r="2"/><circle cx="9" cy="12" r="2"/><circle cx="17" cy="17" r="2"/>'),plus:IC('<path d="M12 5v14M5 12h14"/>'),edit:IC('<path d="M12 20h9"/><path d="M16.4 3.6a2 2 0 0 1 2.83 2.83L7 19.6l-4 1 1-4z"/>'),trash:IC('<path d="M3.5 6h17M9 6V4.2A1.2 1.2 0 0 1 10.2 3h3.6A1.2 1.2 0 0 1 15 4.2V6m3 0v13.5a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6"/><path d="M10 10.5v6M14 10.5v6"/>'),print:IC('<path d="M6.5 9V3.5h11V9"/><rect x="4" y="9" width="16" height="7" rx="2"/><path d="M6.5 15h11v5.5h-11z"/>'),save:IC('<path d="M5 4h11l3 3v13H5z"/><path d="M8 4v5h7"/><path d="M8 20v-6h8v6"/>'),warn:IC('<path d="M12 3.5l9 16H3z"/><path d="M12 10v4.5M12 17.6h.01"/>'),clock:IC('<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5v5l3 2"/>'),down:IC('<path d="M12 3.5v12m0 0l-4-4M12 15.5l4-4"/><path d="M4 20h16"/>'),up:IC('<path d="M12 15.5v-12m0 0l-4 4M12 3.5l4 4"/><path d="M4 20h16"/>'),emp:IC('<rect x="4" y="4" width="16" height="17" rx="2"/><circle cx="12" cy="10" r="2.5"/><path d="M8 17c0-2 1.8-3 4-3s4 1 4 3"/>'),wallet:IC('<rect x="3" y="6" width="18" height="13" rx="2.5"/><path d="M3 10h18"/><circle cx="16.5" cy="14" r="1.2"/>')};
function ic(n){return `<span class="ic">${ICONS[n]||''}</span>`}
const pById=id=>db.products.find(p=>p.id===id)||{};
const sById=id=>db.suppliers.find(s=>s.id===id)||{};
const cById=id=>db.customers.find(c=>c.id===id)||{};
function supplierBalance(id){let t=0;db.purchases.filter(p=>p.supplierId===id).forEach(p=>t+=(p.total-(p.paid||0)));(db.supPays||[]).filter(x=>x.supplierId===id).forEach(x=>t-=(+x.amount||0));return t;}
function customerBalance(id){let t=0;db.sales.filter(s=>s.customerId===id).forEach(s=>t+=(s.total-(s.paid||0)));(db.custPays||[]).filter(p=>p.customerId===id).forEach(p=>t-=(+p.amount||0));return t;}
function stockValue(){return db.products.reduce((a,p)=>a+(p.qty*p.cost),0);}
/* ===== وحدات البيع: مفرق (وحدة) / تجميعة (كرتون-كروز) ===== */
function pk(p){return (p&&p.packSize&&p.packSize>1)?p.packSize:1;}
function hasPack(p){return pk(p)>1;}
function unitLabel(p){return (p&&p.unitName)?p.unitName:'قطعة';}
function packLabel(p){return (p&&p.packName)?p.packName:'كرتون';}
function packPriceOf(p){return (p&&p.packPrice&&p.packPrice>0)?p.packPrice:((p.price||0)*pk(p));}
function packCostOf(p){return (p.cost||0)*pk(p);}
function stockStr(p){const n=pk(p),q=p.qty||0;if(n<=1)return q+' '+unitLabel(p);const full=Math.floor(q/n),rem=q-full*n;return q+' '+unitLabel(p)+' ('+full+' '+packLabel(p)+(rem?' + '+rem:'')+')';}
function clrSearch(){const n=document.getElementById('quickName');if(n)n.value='';const b=document.getElementById('searchRes');if(b)b.innerHTML='';const s=document.getElementById('scan');if(s)s.focus();}
function payExact(){const t=cart.reduce((a,l)=>a+l.price*l.qty,0);const el=document.getElementById('posPaid');if(el){el.value=t;calcChange();}}
function setPaid(v){const el=document.getElementById('posPaid');if(el){el.value=v;calcChange();}}
function quickAddCustomer(){const name=prompt('اسم الزبون الجديد:');if(!name||!name.trim())return;const c={id:uid(),name:name.trim(),phone:'',note:''};db.customers.push(c);save();const sel=document.getElementById('posCustomer');if(sel){sel.innerHTML='<option value="">زبون نقدي</option>'+db.customers.map(x=>`<option value="${x.id}" ${x.id===c.id?'selected':''}>${esc(x.name)}</option>`).join('');}}
function pFillCost(){const id=val('p_prod'),hint=document.getElementById('p_hint'),c=document.getElementById('p_cost');if(!id){if(hint)hint.textContent='';return;}const p=pById(id),mode=val('p_mode');if(c)c.value=(mode==='pack'&&hasPack(p))?packCostOf(p):(p.cost||0);if(hint)hint.textContent=(hasPack(p)?('التجميعة = '+pk(p)+' '+unitLabel(p)):'بدون تجميعة')+' • المخزون الحالي: '+stockStr(p);}
function esc(s){return String(s==null?'':s).replace(/[&<>\"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'}[c]))}

/* ============ التنقل ============ */
const nav=document.getElementById('nav');
const main=document.getElementById('main');
let current='dash';
nav.addEventListener('click',e=>{const a=e.target.closest('a');if(!a)return;current=a.dataset.view;[...nav.children].forEach(x=>x.classList.remove('active'));a.classList.add('active');render();});
const views={dash:renderDash,pos:renderPOS,products:renderProducts,purchases:renderPurchases,sales:renderSales,inventory:renderInventory,suppliers:renderSuppliers,customers:renderCustomers,employees:renderEmployees,reports:renderReports,settings:renderSettings};
function render(){views[current]();}

/* ============ لوحة التحكم ============ */
function renderDash(){
  const salesTotal=db.sales.reduce((a,s)=>a+s.total,0);
  const purchTotal=db.purchases.reduce((a,p)=>a+p.total,0);
  const custDue=db.customers.reduce((a,c)=>a+customerBalance(c.id),0);
  const suppDue=db.suppliers.reduce((a,s)=>a+supplierBalance(s.id),0);
  const low=db.products.filter(p=>p.qty<=(p.min||0));
  const todaySales=db.sales.filter(s=>s.date===today()).reduce((a,s)=>a+s.total,0);
  main.innerHTML=`<div class="topbar"><h1>${ic('dash')} لوحة التحكم — ${esc(db.settings.store)}</h1><div class="flex"><button class="btn ok" onclick="go('pos')">${ic('pos')} فاتورة جديدة</button></div></div>
  <div class="cards">
    <div class="stat"><div class="n" style="color:var(--ok)">${money(todaySales)}</div><div class="l">مبيعات اليوم</div></div>
    <div class="stat"><div class="n">${money(salesTotal)}</div><div class="l">إجمالي المبيعات</div></div>
    <div class="stat"><div class="n">${money(purchTotal)}</div><div class="l">إجمالي المشتريات</div></div>
    <div class="stat"><div class="n" style="color:var(--pri2)">${money(stockValue())}</div><div class="l">قيمة المخزون (كلفة)</div></div>
    <div class="stat"><div class="n" style="color:var(--ok)">${money(custDue)}</div><div class="l">مستحق على الزبائن</div></div>
    <div class="stat"><div class="n" style="color:var(--bad)">${money(suppDue)}</div><div class="l">مستحق للتجار</div></div>
    <div class="stat"><div class="n">${db.products.length}</div><div class="l">عدد الأصناف</div></div>
    <div class="stat"><div class="n" style="color:var(--warn)">${low.length}</div><div class="l">أصناف تحت الحد الأدنى</div></div>
    <div class="stat"><div class="n" style="color:var(--pri2)">${money(db.employees.reduce((a,e)=>a+(empBalance(e.id)>0?empBalance(e.id):0),0))}</div><div class="l">مستحقات العاملين</div></div>
  </div>
  <div class="panel"><h3>${ic('warn')} أصناف قاربت على النفاد</h3>${low.length?tbl(['الباركود','الصنف','المتوفر','الحد الأدنى'],low.map(p=>[p.barcode||'-',esc(p.name),p.qty,p.min||0])):'<div class="small">لا يوجد نقص حالياً.</div>'}</div>
  <div class="panel"><h3>${ic('clock')} آخر الفواتير</h3>${db.sales.slice(-8).reverse().map(s=>`<div class="flex" style="justify-content:space-between;border-bottom:1px solid var(--line);padding:6px 0"><span>#${s.no} — ${esc(cById(s.customerId).name||'نقدي')}</span><span class="small">${s.date}</span><b>${money(s.total)}</b></div>`).join('')||'<div class="small">لا فواتير بعد.</div>'}</div>`;
}
function go(v){current=v;[...nav.children].forEach(x=>x.classList.toggle('active',x.dataset.view===v));render();}
function tbl(head,rows){return `<table><thead><tr>${head.map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${rows.map(r=>`<tr>${r.map(c=>`<td>${c}</td>`).join('')}</tr>`).join('')}</tbody></table>`;}

